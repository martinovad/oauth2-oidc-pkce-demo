# ═══════════════════════════════════════════════════════════════
# OAuth 2.0 + OIDC Demo — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ═══════════════════════════════════════════════════════════════

# ── Auth0 Tenant ─────────────────────────────────────────────
# Found in: Auth0 Dashboard → Applications → Your App → Settings
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_CLIENT_ID=your_client_id_here
AUTH0_CLIENT_SECRET=your_client_secret_here

# ── URLs ─────────────────────────────────────────────────────
# Must be registered in Auth0 Dashboard:
#   Allowed Callback URLs: http://localhost:3001/callback
#   Allowed Logout URLs:   http://localhost:3000
#   Allowed Web Origins:   http://localhost:3000
CALLBACK_URL=http://localhost:3001/callback
FRONTEND_URL=http://localhost:3000

# ── Session Secret ───────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace_with_32+_random_characters_generated_above

# ── Server ───────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
